prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: Mgo
Description: Lick-Mongo Fortran interface for giza
URL: http://giza.sourceforge.net
Version: @VERSION@
Libs: -L${libdir} -lmgo
Requires: giza
Cflags: -I${includedir}
